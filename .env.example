# ════════════════════════════════════════════════════════════════
# SEA Newsletter Generator — Environment Variables
# ════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env to git (it is already in .gitignore)
# ════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: deepseek  (default, cheapest)  |  anthropic
PROVIDER=deepseek

# ── DeepSeek API  (default provider) ─────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
# Pricing: ~$0.27/1M input tokens, ~$1.10/1M output tokens (V3, May 2026)
DEEPSEEK_API_KEY=sk-...

# ── Anthropic API  (optional — only if PROVIDER=anthropic) ───────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily Search API  (web search for news) ──────────────────────────────────
# Free tier: 1,000 searches/month — enough for 4 weekly runs (28 searches each)
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# ── Output ────────────────────────────────────────────────────────────────────
# Where to save generated HTML files.
# Default (./output) works for GitHub Actions automatically.
# Override for local Windows paths:
# OUTPUT_DIR=E:/Work/Weekly report
OUTPUT_DIR=./output

# ── Email delivery ────────────────────────────────────────────────────────────
# The newsletter is emailed automatically after generation.
# Leave EMAIL_FROM empty to skip email sending entirely.
#
# Gmail setup (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password (select "Mail" + "Windows Computer")
#   4. Copy the 16-character password into EMAIL_PASSWORD below
#
# For multiple recipients separate with commas:  a@x.com,b@x.com

EMAIL_FROM=your_gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=recipient1@example.com,recipient2@example.com
EMAIL_CC=

# SMTP server settings (defaults work for Gmail)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ── Advanced (optional) ───────────────────────────────────────────────────────
# Model override (defaults: deepseek-chat | claude-opus-4-7)
# MODEL=deepseek-chat

# Max output tokens. DeepSeek hard limit is 8192; default 7000 leaves headroom.
# MAX_TOKENS=7000

# Search results per query (default 6)
# SEARCH_RESULTS_PER_QUERY=6
